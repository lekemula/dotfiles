{
  "servers": {
    "fetch": {
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/fetch"
      ],
      "command": "docker"
    },
    "github": {
      "headers": {
        "Authorization": "Bearer ${cmd: gh auth token}"
      },
      "url": "https://api.githubcopilot.com/mcp/"
    }
  }
}
